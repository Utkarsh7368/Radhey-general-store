# Server Configuration
PORT=3000

# WhatsApp Cloud API Credentials
# Extract these from your Meta Developer Account Console
WHATSAPP_TOKEN=your_whatsapp_access_token_here
PHONE_NUMBER_ID=your_whatsapp_phone_number_id_here
VERIFY_TOKEN=radhey_store_verify_token_123

# Store Owner Settings
# The phone number (with country code, e.g., 919999999999) to receive new order alerts
OWNER_PHONE=919999999999

# Google Sheets Database Configuration
# The ID of your Google Sheet spreadsheet
SPREADSHEET_ID=your_google_sheet_id_here

# (Optional) paste the raw JSON string of credentials.json here for cloud environments
GOOGLE_SERVICE_ACCOUNT_JSON=

# Template Messaging (for owner alerts to bypass 24-hour window constraint)
# Name of approved utility template in Meta Console (e.g. new_order_alert)
OWNER_TEMPLATE_NAME=
# Language code of approved template (defaults to en)
OWNER_TEMPLATE_LANG=en
